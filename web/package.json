{
  "name": "penalty-king-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile-first web frontend for Penalty King. Runs the Python engine in-browser via Pyodide (same engine as the CLI).",
  "scripts": {
    "copy-engine": "node scripts/copy-engine.mjs",
    "predev": "npm run copy-engine",
    "dev": "vite",
    "prebuild": "npm run copy-engine",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "pyodide": "^0.26.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
